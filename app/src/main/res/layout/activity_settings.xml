<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/main_text" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="12dp"
            android:text="@string/settings_subtitle_admin"
            android:textColor="@color/muted_text" />

        <!-- Крупный баннер статуса защиты — виден сразу при открытии настроек -->
        <LinearLayout
            android:id="@+id/bannerRoleStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="16dp"
            android:background="@color/tile_sos">

            <TextView
                android:id="@+id/tvRoleBannerIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠"
                android:textSize="26sp"
                android:layout_marginEnd="10dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvRoleBannerTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/role_banner_inactive_title"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/main_text" />

                <TextView
                    android:id="@+id/tvRoleBannerDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/role_banner_inactive_desc"
                    android:textSize="13sp"
                    android:textColor="@color/main_text" />
            </LinearLayout>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface_main">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/section_security"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/main_text" />

                    <TextView
                        android:id="@+id/tvRoleStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/role_status_inactive"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/status_error" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="@string/section_security_desc_admin"
                    android:textColor="@color/muted_text" />

                <Button
                    android:id="@+id/btnRequestRole"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_enable_blocking"
                    android:textColor="@color/action_on_primary"
                    android:backgroundTint="@color/action_primary" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="10dp"
                    android:background="@color/tile_default" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/screening_log_label"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/muted_text"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvScreeningLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/screening_log_empty"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/main_text"
                    android:background="@color/input_bg"
                    android:padding="10dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface_main">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/section_allowed_contacts"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/main_text" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/section_allowed_contacts_desc"
                    android:textColor="@color/muted_text" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/tile_default" />

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_contact_name"
                    android:inputType="textPersonName"
                    android:background="@color/input_bg"
                    android:padding="12dp" />

                <EditText
                    android:id="@+id/etNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="@string/hint_contact_number"
                    android:inputType="phone"
                    android:background="@color/input_bg"
                    android:padding="12dp" />

                <TextView
                    android:id="@+id/tvSelectedContactIcon"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/icon_selected_default"
                    android:textColor="@color/muted_text" />

                <Button
                    android:id="@+id/btnPickContactIcon"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/btn_pick_icon"
                    android:textColor="@color/main_text"
                    android:backgroundTint="@color/tile_default" />

                <Button
                    android:id="@+id/btnAddContact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/btn_add_allowed_contact"
                    android:textColor="@color/main_text"
                    android:backgroundTint="@color/tile_contact" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvAllowedContacts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface_main">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/section_main_cells"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/main_text" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/section_main_cells_desc"
                    android:textColor="@color/muted_text" />

                <Button
                    android:id="@+id/btnAddApp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/btn_add_app"
                    android:textColor="@color/main_text"
                    android:backgroundTint="@color/tile_app" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvMainCells"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface_main">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/section_sos"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/main_text" />

                <EditText
                    android:id="@+id/etSosNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="@string/hint_sos_number"
                    android:inputType="phone"
                    android:background="@color/input_bg"
                    android:padding="12dp" />

                <Button
                    android:id="@+id/btnSaveSos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/btn_save_sos"
                    android:textColor="@color/main_text"
                    android:backgroundTint="@color/tile_sos" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/tile_default" />

                <Button
                    android:id="@+id/btnKillLauncher"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_system_settings"
                    android:textColor="@color/main_text"
                    android:backgroundTint="@color/tile_default" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>